class Solution:
    def findRestaurant(self, list1: List[str], list2: List[str]) -> List[str]:
        result = []
        for word in list1:
            if word in list2:
                result.append(word)

        sums = []
        for mot in result:
            sums.append(list1.index(mot) + list2.index(mot))

        minimum = min(sums)

        answer = []
        for i in range(len(result)):
            if sums[i] == minimum:
                answer.append(result[i])

        return answer
        
