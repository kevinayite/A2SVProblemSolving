# Definition for singly-linked list.
# class ListNode:
#     def __init__(self, val=0, next=None):
#         self.val = val
#         self.next = next
class Solution:
    def removeNthFromEnd(self, head: Optional[ListNode], n: int) -> Optional[ListNode]:

        dummy = ListNode(-1, head) # for the value it doesn't matter as we never use it 
        slow = dummy
        fast = dummy

        for _ in range(n+1): # we have the + 1 because we are starting at the dummy
            fast = fast.next
        while fast:
            slow = slow.next
            fast = fast.next
        slow.next = slow.next.next # we are elimiating the element
        return dummy.next

        
