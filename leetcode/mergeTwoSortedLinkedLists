# Definition for singly-linked list.
# class ListNode:
#     def __init__(self, val=0, next=None):
#         self.val = val
#         self.next = next
class Solution:
    def mergeTwoLists(self, list1: Optional[ListNode], list2: Optional[ListNode]) -> Optional[ListNode]:
        dummy = ListNode() # creating an empty one
        current = dummy
        while list1 and list2:
            if list1.val > list2.val:
                current.next = list2
                list2 = list2.next
            else:
                current.next = list1
                list1 = list1.next
            current = current.next # moving forward 
        if list1: # here managing when we have reached the end of the other linked list but having some elements remaining in one of the linked list
            current.next = list1
        else:
            current.next = list2
        return dummy.next
        

        
